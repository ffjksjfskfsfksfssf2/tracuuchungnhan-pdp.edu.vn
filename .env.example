# =============================================================================
# Supabase (project provisioned by PDP admin)
# =============================================================================
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Either the modern publishable key (sb_publishable_...) OR the legacy anon JWT.
# Both work. Prefer publishable when possible.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. NEVER expose to the browser. Used in /api/admin/* routes that
# need to bypass RLS for legitimate admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Site
# =============================================================================
# Used in QR codes and verification links printed onto certificates.
NEXT_PUBLIC_SITE_URL=https://tracuuchungnhan-pdp.edu.vn
NEXT_PUBLIC_VERIFY_BASE_URL=https://tracuuchungnhan-pdp.edu.vn/verify

# =============================================================================
# Google Drive direct upload (M10, optional)
# =============================================================================
# OAuth client ID from Google Cloud Console → APIs & Services → Credentials.
# Type: "Web application". Authorized JavaScript origins MUST include the
# site domain(s) the admin will sign in from, e.g.:
#   - https://tracuuchungnhan-pdp.edu.vn
#   - http://localhost:3000
# No client secret needed — the browser uses GIS Token Client (PKCE-style).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Legacy fields kept for reference — NOT used by the current M10 flow.
# (Will be wired in if/when we add a server-side upload proxy or the
# Google Drive Picker API.)
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=
