# =============================================================================
# Supabase (project provisioned by PDP admin)
# =============================================================================
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Either the modern publishable key (sb_publishable_...) OR the legacy anon JWT.
# Both work. Prefer publishable when possible.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. NEVER expose to the browser. Used in /api/admin/* routes that
# need to bypass RLS for legitimate admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Site
# =============================================================================
# Used in QR codes and verification links printed onto certificates.
NEXT_PUBLIC_SITE_URL=https://tracuuchungnhan-pdp.edu.vn
NEXT_PUBLIC_VERIFY_BASE_URL=https://tracuuchungnhan-pdp.edu.vn/verify

# =============================================================================
# Google Drive (Mode 2 — direct upload, optional. Leave blank for MVP.)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=
